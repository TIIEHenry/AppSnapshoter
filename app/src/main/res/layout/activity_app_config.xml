<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="压缩项目"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/cb_apk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APK" />

        <CheckBox
            android:id="@+id/cb_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data" />

        <CheckBox
            android:id="@+id/cb_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User" />

        <CheckBox
            android:id="@+id/cb_cache"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cache" />

        <CheckBox
            android:id="@+id/cb_user_de"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User DE" />

        <CheckBox
            android:id="@+id/cb_obb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OBB" />

        <CheckBox
            android:id="@+id/cb_external_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="External Data" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="压缩算法"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_compress_algorithm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="留空使用默认" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="其他选项"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/cb_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="保存权限" />

        <CheckBox
            android:id="@+id/cb_enable_sync_to_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启用同步到设备" />

        <CheckBox
            android:id="@+id/cb_enable_sync_to_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="启用同步到系统" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="同步类型"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_sync_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1=最新，n>1=最新的n个"
            android:inputType="number" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="保存" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="重置" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
