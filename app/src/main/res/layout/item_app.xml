<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackgroundBorderless"
    android:padding="8dp">

    <ImageView
        android:id="@+id/app_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="App Icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 运行状态指示器在图标右上角 -->
    <ImageView
        android:id="@+id/app_run_indicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:contentDescription="App Running Status"
        android:src="@drawable/ic_running_indicator"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/app_icon"
        app:layout_constraintTop_toTopOf="@id/app_icon" />

    <!-- Lock指示器在图标右下角 -->
    <ImageView
        android:id="@+id/app_lock_indicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:contentDescription="App Lock Status"
        android:src="@drawable/lock_outline"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/app_icon"
        app:layout_constraintBottom_toBottomOf="@id/app_icon" />

    <TextView
        android:id="@+id/app_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:gravity="center"
        android:lines="2"
        android:maxLines="2"
        android:text="App"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_icon" />

    <!-- 状态指示器 -->
    <ImageView
        android:id="@+id/app_status_indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="2dp"
        android:contentDescription="App Status"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_name" />

</androidx.constraintlayout.widget.ConstraintLayout>