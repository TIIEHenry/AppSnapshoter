<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/item_root_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/icon_root_permission"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="状态"
            android:src="@android:drawable/ic_popup_sync" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="Root权限"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_root_permission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待中"
            android:textColor="?android:textColorSecondary"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progress_root_permission"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_file_system"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/icon_file_system"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="状态"
            android:src="@android:drawable/ic_popup_sync" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="文件系统服务"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_file_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待中"
            android:textColor="?android:textColorSecondary"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progress_file_system"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_app_manager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/icon_app_manager"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="状态"
            android:src="@android:drawable/ic_popup_sync" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="应用管理服务"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/status_app_manager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待中"
            android:textColor="?android:textColorSecondary"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/progress_app_manager"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_error_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:textColor="@android:color/holo_red_dark"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
