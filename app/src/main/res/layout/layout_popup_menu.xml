<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_menu_background"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 上半部分：图标按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btn_shot"
            android:layout_width="@dimen/popup_btn_size"
            android:layout_height="@dimen/popup_btn_size"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="快照"
            android:src="@drawable/archive_arrow_down_outline" />

        <ImageButton
            android:id="@+id/btn_edit"
            android:layout_width="@dimen/popup_btn_size"
            android:layout_height="@dimen/popup_btn_size"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="编辑"
            android:src="@drawable/text_box_edit_outline" />

        <ImageButton
            android:id="@+id/btn_info"
            android:layout_width="@dimen/popup_btn_size"
            android:layout_height="@dimen/popup_btn_size"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="信息"
            android:src="@drawable/information_slab_circle_outline" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="@dimen/popup_btn_size"
            android:layout_height="@dimen/popup_btn_size"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:src="@drawable/cog_transfer" />

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="@dimen/popup_btn_size"
            android:layout_height="@dimen/popup_btn_size"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除"
            android:src="@drawable/delete_forever_outline" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="4dp"
        android:background="@android:color/darker_gray" />

    <!-- 下半部分：存档列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/archive_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxHeight="200dp" />

</LinearLayout>